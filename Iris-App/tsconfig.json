{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    "moduleResolution": "bundler",   // works best with Vite 5
    "types": ["node"],               // fixes Buffer, process, etc.
    "esModuleInterop": true,         // allows default-import React / react-dom
    "skipLibCheck": true,

    "strict": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "typeRoots": ["./src/types", "./node_modules/@types"]
  },
  "include": ["src"]
}
