{
  "name": "iris-vcode",
  "displayName": "iris-vcode",
  "description": "Iris for Godot - local-first assistant",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:iris.openChat",
    "onCommand:iris.openChatTerminal",
    "onCommand:iris.toggleOnline"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      { "command": "iris.openChat", "title": "Iris: Open Chat" },
      { "command": "iris.openChatTerminal", "title": "Iris: Open Chat Terminal" },
      { "command": "iris.toggleOnline", "title": "Iris: Toggle Online Assistance" }
    ],
    "configuration": {
      "title": "Iris",
      "properties": {
        "iris.onlineAssistance": {
          "type": "boolean",
          "default": false,
          "description": "Optional Online: make qwen2.5/llama3 run more efficiently (user toggle)."
        },
        "iris.permaprompt": {
          "type": "string",
          "default": "Cheerfully diligent. Always diff-based. Verify Godot APIs.",
          "description": "Project permaprompt used by Iris."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.103.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^9.34.0",
    "esbuild": "^0.25.9",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.2",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
